{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist-electron",
    "rootDir": "./electron",
    "types": ["node", "electron"],
    "isolatedModules": false,
    "noImplicitOverride": false
  },
  "include": ["electron/**/*.ts"]
}
